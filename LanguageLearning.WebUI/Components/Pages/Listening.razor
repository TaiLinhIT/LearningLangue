@page "/listening"
@rendermode InteractiveServer

<section class="app-section">
    <div class="section-title">
        <h1>Luyen nghe va phat am</h1>
        <p>Khung bai nghe dien tu, ghi am giong noi va so sanh phat am o muc demo.</p>
    </div>

    <div class="grid grid-2">
        <article class="cardx">
            <span class="pill">Audio 00:38</span>
            <h3 class="mt-3">Dien tu con thieu</h3>
            <p class="muted">Cau nghe: "I have a ____ at nine and a report due Friday."</p>
            <input class="form-control" value="@BlankAnswer" @oninput="UpdateBlankAnswer" placeholder="Nhap tu ban nghe duoc" />
            <button class="btn btn-primary mt-3" @onclick="CheckBlank">Cham bai nghe</button>
            @if (!string.IsNullOrWhiteSpace(ListeningMessage))
            {
                <div class="alert alert-info mt-3">@ListeningMessage</div>
            }
        </article>

        <article class="cardx">
            <span class="pill">Mic demo</span>
            <h3 class="mt-3">Ghi am phat am</h3>
            <p class="muted">Doc cau: "Nice to meet you." He thong hien trang thai san sang de sau nay ket noi Web Speech API.</p>
            <button class="btn btn-outline-primary" @onclick="StartRecording">Bat dau ghi am</button>
            <button class="btn btn-primary ms-2" @onclick="ComparePronunciation">So sanh phat am</button>
            <div class="progress mt-3">
                <div class="progress-bar bg-success" style="width:@PronunciationScore%"></div>
            </div>
            <p class="muted mt-2">Do tu tin: @PronunciationScore%</p>
        </article>
    </div>
</section>

@code {
    private string? BlankAnswer;
    private string? ListeningMessage;
    private int PronunciationScore = 0;

    private void UpdateBlankAnswer(ChangeEventArgs args)
    {
        BlankAnswer = args.Value?.ToString();
    }

    private void CheckBlank()
    {
        ListeningMessage = string.Equals(BlankAnswer?.Trim(), "meeting", StringComparison.OrdinalIgnoreCase)
            ? "Dung. meeting = cuoc hop."
            : "Chua dung. Goi y: tu nay lien quan den cuoc hop.";
    }

    private void StartRecording() => PronunciationScore = 35;

    private void ComparePronunciation() => PronunciationScore = 82;
}

