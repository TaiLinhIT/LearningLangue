@page "/roadmap"
@inject ILearningCatalogService Catalog

<section class="app-section">
    <div class="section-title">
        <h1>Lo trinh hoc</h1>
        <p>Di theo tung node bai hoc, mo khoa cap do moi khi hoan thanh muc tieu trong ngay.</p>
    </div>

    <div class="grid grid-2">
        <article class="cardx">
            <span class="pill green">Dang hoc</span>
            <h3 class="mt-3">English A2 Sprint</h3>
            <p class="muted">Tap trung giao tiep cong viec, nghe ngan va tu vung moi ngay.</p>
            <div class="progress mb-3">
                <div class="progress-bar" style="width:68%"></div>
            </div>
            <a class="btn btn-primary" href="lessons">Tiep tuc</a>
        </article>
        <article class="cardx">
            <span class="pill yellow">Thu thach tuan</span>
            <h3 class="mt-3">5 ngay lien tiep</h3>
            <p class="muted">Hoan thanh it nhat mot quiz moi ngay de nhan bonus XP.</p>
            <div class="mini-stat-grid">
                <div class="mini-stat"><strong>12</strong><span class="muted">Streak</span></div>
                <div class="mini-stat"><strong>247</strong><span class="muted">Tu</span></div>
                <div class="mini-stat"><strong>86%</strong><span class="muted">Score</span></div>
            </div>
        </article>
    </div>

    <div class="section-title mt-5">
        <h2>Skill path</h2>
    </div>

    <div class="lesson-path">
        @foreach (var skill in Catalog.GetProgress().Skills)
        {
            var dotClass = skill.Progress > 65 ? "" : skill.Progress > 45 ? "blue" : "yellow";
            <article class="cardx lesson-node">
                <span class="lesson-dot @dotClass">@skill.Icon</span>
                <div>
                    <h3 class="mb-1">@skill.Name</h3>
                    <p class="muted mb-2">@skill.Description</p>
                    <div class="progress">
                        <div class="progress-bar" style="width:@skill.Progress%"></div>
                    </div>
                </div>
                <a class="btn btn-outline-primary" href="lessons">Luyen</a>
            </article>
        }
    </div>
</section>
