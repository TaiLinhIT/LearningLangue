@page "/lesson/{Id:int}"
@attribute [Authorize(Roles = "Learner,Admin")]
@layout LanguageLearning.WebUI.Components.Layout.LearnerLayout
@inject ILearningCatalogService Catalog

<section class="workspace-section">
    @if (_lesson is null)
    {
        <div class="loading-state">Loading lesson...</div>
    }
    else
    {
        <div class="lesson-hero">
            <span class="pill">@_lesson.LessonType</span>
            <h1>@_lesson.Title</h1>
            <p>@_lesson.Description</p>
            <div class="hero-actions">
                <a class="btn btn-primary" href="/quiz/@_lesson.Id">Start quiz</a>
                <a class="btn btn-light" href="/practice">Practice</a>
            </div>
        </div>

        <div class="grid grid-2">
            <article class="cardx">
                <h3>Learn Vocabulary</h3>
                @foreach (var word in _lesson.Vocabulary)
                {
                    <div class="vocab-row">
                        <strong>@word.Word</strong>
                        <span>@word.Meaning</span>
                        <small>@word.ExampleSentence</small>
                    </div>
                }
            </article>
            <article class="cardx">
                <h3>Practice Modes</h3>
                <div class="practice-grid">
                    <a href="/practice/vocabulary">Vocabulary Quiz</a>
                    <a href="/practice/listening">Listening Quiz</a>
                    <a href="/practice/speaking">Speaking Practice</a>
                    <a href="/practice/grammar">Grammar Quiz</a>
                </div>
            </article>
        </div>
    }
</section>

@code {
    [Parameter] public int Id { get; set; }
    private Lesson? _lesson;

    protected override async Task OnParametersSetAsync()
    {
        _lesson = await Catalog.GetLessonAsync(Id);
    }
}
