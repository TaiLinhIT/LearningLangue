@page "/account"

<section class="app-section">
    <div class="section-title">
        <h1>Quan ly tai khoan</h1>
        <p>Thong tin ca nhan, ngon ngu dang hoc, muc tieu va lich su hoc tap.</p>
    </div>

    <div class="grid grid-2">
        <article class="cardx">
            <h3>Ho so ca nhan</h3>
            <label class="form-label mt-3">Ho ten</label>
            <input class="form-control" value="Nguyen Linh" />
            <label class="form-label mt-3">Email</label>
            <input class="form-control" value="linh@example.com" />
            <label class="form-label mt-3">Muc tieu moi ngay</label>
            <select class="form-select">
                <option>15 phut/ngay</option>
                <option>30 phut/ngay</option>
                <option>60 phut/ngay</option>
            </select>
            <button class="btn btn-primary mt-4">Luu thay doi</button>
        </article>

        <article class="cardx">
            <h3>Lich su hoc tap</h3>
            <ul class="list-group list-group-flush">
                <li class="list-group-item">Hoan thanh: Chao hoi va gioi thieu ban than</li>
                <li class="list-group-item">Quiz cong viec: 8/10</li>
                <li class="list-group-item">On 24 flashcard tu vung</li>
                <li class="list-group-item">Streak hien tai: 12 ngay</li>
            </ul>
        </article>
    </div>
</section>

