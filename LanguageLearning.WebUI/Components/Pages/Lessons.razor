@page "/lessons"
@inject ILearningCatalogService Catalog

<section class="app-section">
    <div class="section-title">
        <h1>Bai hoc tuong tac</h1>
        <p>Moi bai co noi dung hoc, vi du, cau hoi luyen tap va giai thich dap an.</p>
    </div>

    <div class="grid">
        @foreach (var lesson in Catalog.GetLessons())
        {
            <article class="cardx lesson-row">
                <div>
                    <div class="d-flex flex-wrap gap-2 mb-2">
                        <span class="pill">@lesson.Level</span>
                        <span class="pill">@lesson.Skill</span>
                        <span class="pill">@lesson.DurationMinutes phut</span>
                        @if (lesson.IsPremium)
                        {
                            <span class="pill">Plus</span>
                        }
                    </div>
                    <h3>@lesson.Title</h3>
                    <p class="muted mb-0">@lesson.Summary</p>
                </div>
                <a class="btn btn-primary" href="lesson/@lesson.Id">Hoc ngay</a>
            </article>
        }
    </div>
</section>

