@page "/dictionary"
@rendermode InteractiveServer
@inject ILearningCatalogService Catalog

<section class="app-section">
    <div class="section-title">
        <h1>Tu dien / Tra cuu nhanh</h1>
        <p>Tra tu, xem nghia, phien am, vi du va nut phat am mau.</p>
    </div>

    <div class="cardx form-shell">
        <div class="input-group">
            <input class="form-control" @bind="Query" @bind:event="oninput" placeholder="Nhap tu, nghia hoac chu de" />
            <button class="btn btn-primary" @onclick="Search">Tra cuu</button>
        </div>
    </div>

    <div class="grid grid-3 mt-3">
        @foreach (var item in Results)
        {
            <article class="cardx">
                <span class="pill">@item.LanguageCode.ToUpperInvariant() - @item.Topic</span>
                <h3 class="mt-3">@item.Term</h3>
                <p>@item.Phonetic</p>
                <p><strong>@item.Meaning</strong></p>
                <p class="muted">@item.Example</p>
                <button class="btn btn-sm btn-outline-primary">Phat am</button>
            </article>
        }
    </div>
</section>

@code {
    private string? Query;
    private IReadOnlyList<VocabularyItem> Results = [];

    protected override void OnInitialized()
    {
        Results = Catalog.GetVocabulary();
    }

    private void Search()
    {
        Results = Catalog.GetVocabulary(Query);
    }
}

