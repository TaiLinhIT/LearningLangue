@page "/languages"
@inject ILearningCatalogService Catalog

<section class="app-section">
    <div class="section-title">
        <h1>Chon ngon ngu hoc</h1>
        <p>Moi ngon ngu co lo trinh rieng, tu vung mau, bai luyen nghe noi va bai kiem tra tu dong.</p>
    </div>

    <div class="grid grid-3">
        @foreach (var language in Catalog.GetLanguages())
        {
            <article class="cardx">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="pill">@language.Flag @language.NativeName</span>
                    <span class="pill">@language.Difficulty</span>
                </div>
                <h3 class="mt-3">@language.Name</h3>
                <p class="muted">@language.Description</p>
                <div class="d-flex justify-content-between align-items-center">
                    <span>@language.Learners.ToString("N0") hoc vien</span>
                    <a class="btn btn-sm btn-primary" href="roadmap">Chon</a>
                </div>
            </article>
        }
    </div>
</section>

