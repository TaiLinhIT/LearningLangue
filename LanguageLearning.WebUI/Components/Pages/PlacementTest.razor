@page "/placement-test"
@rendermode InteractiveServer
@inject ILearningCatalogService Catalog

<section class="app-section">
    <div class="section-title">
        <h1>Kiem tra trinh do dau vao</h1>
        <p>Tra loi nhanh de he thong goi y muc A1, A2, B1, B2 hoac C1.</p>
    </div>

    <div class="cardx form-shell">
        @for (var i = 0; i < Questions.Count; i++)
        {
            var index = i;
            var question = Questions[index];
            <div class="mb-4">
                <span class="pill">@question.Skill</span>
                <h3 class="mt-2">@(index + 1). @question.Prompt</h3>
                <div class="grid grid-2 mt-3">
                    @for (var j = 0; j < question.Options.Count; j++)
                    {
                        var optionIndex = j;
                        <button class="answer-button @(Selected.GetValueOrDefault(index, -1) == optionIndex ? "selected" : "")"
                                @onclick="() => Selected[index] = optionIndex">
                            @question.Options[optionIndex]
                        </button>
                    }
                </div>
            </div>
        }
        <button class="btn btn-primary" @onclick="Calculate">Xem ket qua</button>
    </div>

    @if (Result is not null)
    {
        <div class="alert alert-info mt-3 form-shell">
            Diem cua ban: @Score/@Questions.Count. Goi y bat dau o muc <strong>@Result</strong>.
        </div>
    }
</section>

@code {
    private IReadOnlyList<PlacementQuestion> Questions = [];
    private Dictionary<int, int> Selected = [];
    private int Score;
    private string? Result;

    protected override void OnInitialized()
    {
        Questions = Catalog.GetPlacementQuestions();
    }

    private void Calculate()
    {
        Score = Questions.Where((question, index) => Selected.TryGetValue(index, out var answer) && answer == question.CorrectIndex).Count();
        Result = Score switch
        {
            <= 1 => "A1",
            2 => "A2",
            3 => "B1",
            4 => "B2",
            _ => "C1"
        };
    }
}

