@page "/vocabulary"
@rendermode InteractiveServer
@inject ILearningCatalogService Catalog

<section class="app-section">
    <div class="section-title">
        <h1>Luyen tu vung</h1>
        <p>Flashcard, phien am, cau vi du va danh sach tu da hoc/de on tap.</p>
    </div>

    <div class="grid grid-2">
        <article class="cardx">
            <div class="flashcard">
                <div>
                    <strong>@Current.Term</strong>
                    <p class="mt-2 mb-0">@Current.Phonetic</p>
                    @if (ShowMeaning)
                    {
                        <p class="mt-3 mb-0">@Current.Meaning</p>
                        <small>@Current.Example</small>
                    }
                </div>
            </div>
            <div class="d-flex flex-wrap gap-2 mt-3">
                <button class="btn btn-outline-primary" @onclick="() => ShowMeaning = !ShowMeaning">Lat the</button>
                <button class="btn btn-outline-secondary" @onclick="Previous">Truoc</button>
                <button class="btn btn-primary" @onclick="Next">Tiep theo</button>
                <button class="btn btn-outline-secondary">Phat am</button>
            </div>
        </article>

        <article class="cardx">
            <h3>Danh sach on tap</h3>
            <div class="table-responsive table-clean mt-3">
                <table class="table">
                    <thead><tr><th>Tu</th><th>Nghia</th><th>Chu de</th><th>Trang thai</th></tr></thead>
                    <tbody>
                        @foreach (var item in Words)
                        {
                            <tr>
                                <td>@item.Term</td>
                                <td>@item.Meaning</td>
                                <td>@item.Topic</td>
                                <td>@(item.Learned ? "Da hoc" : "Can on")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </article>
    </div>
</section>

@code {
    private IReadOnlyList<VocabularyItem> Words = [];
    private int Index;
    private bool ShowMeaning;
    private VocabularyItem Current => Words[Index];

    protected override void OnInitialized()
    {
        Words = Catalog.GetVocabulary();
    }

    private void Next()
    {
        Index = (Index + 1) % Words.Count;
        ShowMeaning = false;
    }

    private void Previous()
    {
        Index = Index == 0 ? Words.Count - 1 : Index - 1;
        ShowMeaning = false;
    }
}

