@page "/login"
@page "/auth"
@inject NavigationManager Navigation

<section class="app-section auth-page">
    <AuthorizeView>
        <Authorized Context="authContext">
            <MudPaper Elevation="0" Class="auth-signed-in-panel">
                <div class="auth-badge">
                    <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" />
                </div>
                <div>
                    <span class="eyebrow">Da dang nhap</span>
                    <h1>@GetDisplayName(authContext.User)</h1>
                    <p>Ban dang hoc voi tai khoan @GetEmail(authContext.User). Tiep tuc vao ho so de xem muc tieu va tien do hoc tap.</p>
                    <div class="auth-inline-actions">
                        <MudButton Href="account"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.AccountCircle"
                                   Class="duo-button">
                            Xem tai khoan
                        </MudButton>
                        <form method="post" action="/auth/sign-out">
                            <MudButton ButtonType="ButtonType.Submit"
                                       Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       StartIcon="@Icons.Material.Filled.Logout"
                                       Class="duo-button secondary">
                                Dang xuat
                            </MudButton>
                        </form>
                    </div>
                </div>
            </MudPaper>
        </Authorized>
        <NotAuthorized>
            <div class="auth-modal-shell">
                <div class="auth-modal" role="dialog" aria-labelledby="auth-title">
                    <a class="auth-close" href="/" aria-label="Đóng">
                        <MudIcon Icon="@Icons.Material.Filled.Close" />
                    </a>

                    <div class="auth-brand-mark">LinguaFlow</div>

                    <h1 id="auth-title">@PageTitle</h1>
                    <p class="auth-warning">Mỗi người nên sử dụng riêng một tài khoản, tài khoản nhiều người sử dụng chung sẽ bị khóa.</p>

                    @if (!string.IsNullOrWhiteSpace(Message))
                    {
                        <MudAlert Severity="@AlertSeverity"
                                  Variant="Variant.Filled"
                                  Class="auth-message auth-modal-message">
                            @Message
                        </MudAlert>
                    }

                    @if (IsForgotMode)
                    {
                        <form method="post" action="/auth/forgot-password" class="auth-email-form auth-forgot-panel">
                            <label class="auth-label" for="forgot-email">Email cần khôi phục</label>
                            <input id="forgot-email"
                                   class="auth-input"
                                   name="email"
                                   type="email"
                                   autocomplete="email"
                                   placeholder="ban@example.com"
                                   required />

                            <button class="auth-submit-button" type="submit">
                                Gửi hướng dẫn
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="auth-social-stack">
                            <form method="post" action="/auth/external/google">
                                <button class="auth-social-button" type="submit">
                                    <span class="auth-provider-icon google">G</span>
                                    <span>@ActionText với Google</span>
                                </button>
                            </form>
                            <form method="post" action="/auth/external/facebook">
                                <button class="auth-social-button" type="submit">
                                    <span class="auth-provider-icon facebook">f</span>
                                    <span>@ActionText với Facebook</span>
                                </button>
                            </form>
                            <form method="post" action="/auth/external/github">
                                <button class="auth-social-button" type="submit">
                                    <span class="auth-provider-icon github">GH</span>
                                    <span>@ActionText với Github</span>
                                </button>
                            </form>
                        </div>

                        <details class="auth-email-details">
                            <summary class="auth-social-button auth-email-summary">
                                <span class="auth-provider-icon email">
                                    <MudIcon Icon="@Icons.Material.Filled.PersonOutline" />
                                </span>
                                <span>Sử dụng email / số điện thoại</span>
                            </summary>

                            @if (IsRegisterMode)
                            {
                                <form method="post" action="/auth/register" class="auth-email-form">
                                    <label class="auth-label" for="register-name">Họ tên</label>
                                    <input id="register-name"
                                           class="auth-input"
                                           name="fullName"
                                           autocomplete="name"
                                           placeholder="Nguyen Van A"
                                           minlength="2"
                                           required />

                                    <label class="auth-label" for="register-email">Email</label>
                                    <input id="register-email"
                                           class="auth-input"
                                           name="email"
                                           type="email"
                                           autocomplete="email"
                                           placeholder="ban@example.com"
                                           required />

                                    <label class="auth-label" for="register-goal">Mục tiêu học</label>
                                    <select id="register-goal" class="auth-input" name="learningGoal">
                                        <option>Giao tiếp hằng ngày</option>
                                        <option>Thi chứng chỉ</option>
                                        <option>Công việc</option>
                                        <option>Du học</option>
                                    </select>

                                    <div class="auth-two-fields">
                                        <div>
                                            <label class="auth-label" for="register-password">Mật khẩu</label>
                                            <input id="register-password"
                                                   class="auth-input"
                                                   name="password"
                                                   type="password"
                                                   autocomplete="new-password"
                                                   minlength="6"
                                                   placeholder="Ít nhất 6 ký tự"
                                                   required />
                                        </div>
                                        <div>
                                            <label class="auth-label" for="register-confirm">Nhập lại</label>
                                            <input id="register-confirm"
                                                   class="auth-input"
                                                   name="confirmPassword"
                                                   type="password"
                                                   autocomplete="new-password"
                                                   minlength="6"
                                                   placeholder="Nhập lại mật khẩu"
                                                   required />
                                        </div>
                                    </div>

                                    <button class="auth-submit-button" type="submit">
                                        Đăng ký tài khoản
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form method="post" action="/auth/sign-in" class="auth-email-form">
                                    <label class="auth-label" for="login-email">Email</label>
                                    <input id="login-email"
                                           class="auth-input"
                                           name="email"
                                           type="email"
                                           autocomplete="email"
                                           placeholder="ban@example.com"
                                           required />

                                    <label class="auth-label" for="login-password">Mật khẩu</label>
                                    <input id="login-password"
                                           class="auth-input"
                                           name="password"
                                           type="password"
                                           autocomplete="current-password"
                                           placeholder="Nhập mật khẩu"
                                           required />

                                    <label class="auth-check">
                                        <input type="checkbox" name="remember" checked />
                                        <span>Ghi nhớ đăng nhập trong 14 ngày</span>
                                    </label>

                                    <button class="auth-submit-button" type="submit">
                                        Đăng nhập
                                    </button>
                                </form>
                            }
                        </details>
                    }

                    <div class="auth-switch-line">
                        @if (IsForgotMode)
                        {
                            <span>Đã nhớ mật khẩu?</span>
                            <a href="/auth?mode=login">Đăng nhập</a>
                        }
                        else if (IsRegisterMode)
                        {
                            <span>Bạn đã có tài khoản?</span>
                            <a href="/auth?mode=login">Đăng nhập</a>
                        }
                        else
                        {
                            <span>Bạn chưa có tài khoản?</span>
                            <a href="/auth?mode=register">Đăng ký</a>
                        }
                    </div>

                    @if (!IsForgotMode)
                    {
                        <a class="auth-forgot-link" href="/auth?mode=forgot">Quên mật khẩu?</a>
                    }

                    <p class="auth-terms">
                        Việc bạn tiếp tục sử dụng trang web này đồng nghĩa bạn đồng ý với
                        <a href="/pricing">điều khoản sử dụng</a> của chúng tôi.
                    </p>
                </div>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</section>

@code {
    [SupplyParameterFromQuery(Name = "mode")]
    public string? Mode { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    public string? Status { get; set; }

    [SupplyParameterFromQuery(Name = "message")]
    public string? Message { get; set; }

    private bool IsRegisterMode =>
        string.Equals(Mode, "register", StringComparison.OrdinalIgnoreCase);

    private bool IsForgotMode =>
        string.Equals(Mode, "forgot", StringComparison.OrdinalIgnoreCase);

    private string PageTitle =>
        IsForgotMode
            ? "Khôi phục mật khẩu LinguaFlow"
            : IsRegisterMode
                ? "Đăng ký tài khoản LinguaFlow"
                : "Đăng nhập vào LinguaFlow";

    private string ActionText => IsRegisterMode ? "Đăng ký" : "Đăng nhập";

    private Severity AlertSeverity =>
        string.Equals(Status, "error", StringComparison.OrdinalIgnoreCase)
            ? Severity.Error
            : Severity.Success;

    private static string GetDisplayName(ClaimsPrincipal user) =>
        user.Identity?.Name ?? user.FindFirstValue(ClaimTypes.Email) ?? "Tai khoan";

    private static string GetEmail(ClaimsPrincipal user) =>
        user.FindFirstValue(ClaimTypes.Email) ?? "email chua cap nhat";
}
