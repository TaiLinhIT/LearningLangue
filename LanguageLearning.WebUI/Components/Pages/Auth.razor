@page "/login"
@page "/auth"
@inject NavigationManager Navigation

<section class="auth-page">
    <div class="auth-panel">
        <span class="pill">Welcome back</span>
        <h1>Login</h1>
        @if (HasError)
        {
            <div class="error-state">Email or password is incorrect.</div>
        }
        <form method="post" action="/account/login" class="form-stack">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <label>Email<input name="email" type="email" value="@Email" required /></label>
            <label>Password<input name="password" type="password" required /></label>
            <button class="btn btn-primary btn-lg" type="submit">Login</button>
        </form>
        <p class="muted">Demo admin: admin@linguaflow.local / Admin@123</p>
        <p class="muted">Demo learner: learner@linguaflow.local / Learner@123</p>
        <a href="/register">Create a learner account</a>
    </div>
</section>

@code {
    private bool HasError => Navigation.Uri.Contains("error=1", StringComparison.OrdinalIgnoreCase);
    private string Email => Query("email") ?? string.Empty;
    private string ReturnUrl => Query("returnUrl") ?? string.Empty;

    private string? Query(string key)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue(key, out var value) ? value.ToString() : null;
    }
}
