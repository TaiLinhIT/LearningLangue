@page "/progress"
@page "/result"
@attribute [Authorize(Roles = "Learner,Admin")]
@layout LanguageLearning.WebUI.Components.Layout.LearnerLayout
@inject ILearningCatalogService Catalog
@inject AuthenticationStateProvider AuthState

<section class="workspace-section">
    <div class="section-title">
        <h1>Progress</h1>
        <p>Track score, XP, completed lessons, and skill momentum.</p>
    </div>

    @if (_progress is null)
    {
        <div class="loading-state">Loading progress...</div>
    }
    else if (_progress.Count == 0)
    {
        <div class="empty-state">No completed lesson yet. Start a quiz to create progress.</div>
    }
    else
    {
        <div class="grid grid-2">
            @foreach (var item in _progress)
            {
                <article class="cardx">
                    <span class="pill">@item.Status</span>
                    <h3>@item.Lesson?.Title</h3>
                    <p class="muted">@item.Lesson?.Unit?.Course?.Title</p>
                    <div class="progress-shell"><div style="width:@item.Score%"></div></div>
                    <strong>@item.Score% - @item.XP XP</strong>
                </article>
            }
        </div>
    }
</section>

@code {
    private IReadOnlyList<UserLessonProgress>? _progress;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var userId = int.Parse(auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0");
        _progress = await Catalog.GetProgressAsync(userId);
    }
}
