@page "/"
@inject ILearningCatalogService Catalog

<section class="hero app-section">
    <div>
        <span class="pill mb-3">Hoc ngon ngu theo CEFR, co lo trinh va quiz tu dong</span>
        <h1>LinguaFlow</h1>
        <p class="mt-3">Website hoc ngoai ngu hoan chinh cho nguoi moi bat dau den trinh do nang cao: chon ngon ngu, test dau vao, hoc theo lo trinh, luyen tu vung, nghe noi, lam bai kiem tra va theo doi tien do.</p>
        <div class="d-flex flex-wrap gap-2 mt-4">
            <a class="btn btn-primary btn-lg" href="languages">Bat dau hoc</a>
            <a class="btn btn-light btn-lg" href="auth">Dang ky mien phi</a>
        </div>
    </div>
</section>

<section class="app-section">
    <div class="section-title">
        <h2>Ngon ngu co the hoc</h2>
        <p>Khoi dau voi nhung ngon ngu pho bien, moi ngon ngu co bai hoc theo cap do, chu de va ky nang.</p>
    </div>
    <div class="grid grid-3">
        @foreach (var language in Catalog.GetLanguages())
        {
            <article class="cardx">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <span class="pill">@language.Flag</span>
                        <h3 class="mt-3">@language.Name</h3>
                    </div>
                    <span class="pill">@language.Difficulty</span>
                </div>
                <p class="muted">@language.Description</p>
                <strong>@language.Learners.ToString("N0")</strong> hoc vien dang hoc
            </article>
        }
    </div>
</section>

<section class="app-section pt-0">
    <div class="grid grid-4">
        <div class="cardx stat"><h3>Test dau vao</h3><p class="muted">Xac dinh A1, A2, B1, B2, C1 bang bai test ngan.</p></div>
        <div class="cardx stat"><h3>Bai hoc tuong tac</h3><p class="muted">Noi dung, vi du, audio gia lap, cau hoi va giai thich dap an.</p></div>
        <div class="cardx stat"><h3>Theo doi tien do</h3><p class="muted">Bai da hoc, diem trung binh, streak va ky nang manh yeu.</p></div>
        <div class="cardx stat"><h3>Quan tri noi dung</h3><p class="muted">Khung admin de quan ly nguoi dung, khoa hoc va bao cao.</p></div>
    </div>
</section>

