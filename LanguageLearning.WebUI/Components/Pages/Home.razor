@page "/"
@page "/about"
@inject ILearningCatalogService Catalog

@{
    var progress = _summary ?? new DashboardSummary(0, 0, 0, 0, 0);
    var recommendedCourses = _courses.Take(6).ToList();
    var freeCount = _courses.Count(course => !IsPremiumCourse(course));
    var premiumCount = _courses.Count(IsPremiumCourse);
}

<div class="home-page">
    <section class="banner-section" aria-label="Quang cao khoa hoc">
        <div class="banner-window">
            <div class="ad-slider">
                <article class="ad-slide ad-slide-green">
                    <div class="banner-copy">
                        <span class="eyebrow">LinguaFlow Plus</span>
                        <h1>Hoc ngon ngu moi ngay voi cac bai ngan cuc vui</h1>
                        <p>Mo khoa lo trinh A1 den B1, quiz nhanh, streak va diem XP de viec hoc nhe nhu mot van choi.</p>
                        <div class="banner-actions">
                            <MudButton Href="lessons"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       StartIcon="@Icons.Material.Filled.PlayArrow"
                                       Class="duo-button">
                                Bat dau hoc
                            </MudButton>
                            <MudButton Href="placement-test"
                                       Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       Size="Size.Large"
                                       Class="duo-button secondary">
                                Test dau vao
                            </MudButton>
                        </div>
                    </div>

                    <div class="banner-visual" aria-hidden="true">
                        <div class="lesson-orbit">
                            <span class="orbit-token token-main">LF</span>
                            <span class="orbit-token token-small token-blue">A1</span>
                            <span class="orbit-token token-small token-yellow">XP</span>
                            <span class="orbit-token token-small token-coral">B1</span>
                        </div>
                        <div class="streak-card">
                            <MudIcon Icon="@Icons.Material.Filled.LocalFireDepartment" />
                            <strong>@progress.CurrentStreak ngay</strong>
                            <span>streak dang chay</span>
                        </div>
                    </div>
                </article>

                <article class="ad-slide ad-slide-blue">
                    <div class="banner-copy">
                        <span class="eyebrow">Theo doi chung toi</span>
                        <h2>Video ngan moi ngay tren TikTok, YouTube va Facebook</h2>
                        <p>Hoc phat am, cau giao tiep va meo ghi nho tu vung bang cac clip gon, nhanh, de xem lai.</p>
                        <div class="social-row">
                            @foreach (var social in SocialLinks)
                            {
                                <a class="social-link" href="@social.Url" target="_blank" rel="noopener">
                                    <MudIcon Icon="@social.Icon" Size="Size.Small" />
                                    <span>@social.Name</span>
                                </a>
                            }
                        </div>
                    </div>

                    <div class="video-stack" aria-hidden="true">
                        <div class="video-card active">
                            <MudIcon Icon="@Icons.Material.Filled.MusicNote" />
                            <strong>60s Speaking</strong>
                            <span>Clip moi moi ngay</span>
                        </div>
                        <div class="video-card">
                            <MudIcon Icon="@Icons.Material.Filled.OndemandVideo" />
                            <strong>Lesson Shorts</strong>
                            <span>Bai hoc ngan</span>
                        </div>
                        <div class="video-card">
                            <MudIcon Icon="@Icons.Material.Filled.ThumbUp" />
                            <strong>Community</strong>
                            <span>Hoi dap nhanh</span>
                        </div>
                    </div>
                </article>

                <article class="ad-slide ad-slide-yellow">
                    <div class="banner-copy">
                        <span class="eyebrow">Khoa hoc moi</span>
                        <h2>Chon mien phi truoc, nang cap Plus khi can luyen sau hon</h2>
                        <p>Co @freeCount khoa mien phi de bat dau va @premiumCount khoa Plus cho ngu phap, nghe noi va lo trinh nang cao.</p>
                        <div class="banner-actions">
                            <MudButton Href="pricing"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       StartIcon="@Icons.Material.Filled.Star"
                                       Class="duo-button">
                                Xem goi hoc
                            </MudButton>
                            <MudButton Href="roadmap"
                                       Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       Size="Size.Large"
                                       Class="duo-button secondary">
                                Xem lo trinh
                            </MudButton>
                        </div>
                    </div>

                    <div class="pricing-preview" aria-hidden="true">
                        <div class="price-tile free">
                            <span>Mien phi</span>
                            <strong>@freeCount khoa</strong>
                        </div>
                        <div class="price-tile plus">
                            <span>Plus</span>
                            <strong>@premiumCount khoa</strong>
                        </div>
                    </div>
                </article>
            </div>
        </div>

        <div class="slider-dots" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </section>

    <section class="app-section recommended-section">
        <div class="section-title home-title">
            <span class="eyebrow">Danh cho ban</span>
            <h2>Khoa hoc phu hop hom nay</h2>
            <p>Card khoa hoc duoc sap xep de ban co the bat dau mien phi, sau do nang cap khi muon luyen sau hon.</p>
        </div>

        <div class="course-grid">
            @foreach (var course in recommendedCourses)
            {
                var isPremium = IsPremiumCourse(course);
                var progressValue = GetCourseProgress(course);

                <MudPaper Elevation="0" Class="@($"course-card {GetCourseTone(course)} {(isPremium ? "premium" : "free")}")">
                    <div class="course-topline">
                        <span class="course-tag @(isPremium ? "premium" : "free")">
                            <MudIcon Icon="@(isPremium ? Icons.Material.Filled.Lock : Icons.Material.Filled.LockOpen)" Size="Size.Small" />
                            @(isPremium ? "Tra phi" : "Mien phi")
                        </span>
                        <span class="level-pill">@course.Level</span>
                    </div>

                    <div class="course-token">
                        <MudIcon Icon="@GetCourseIcon(course)" />
                    </div>

                    <h3>@course.Title</h3>
                    <p>@course.Description</p>

                    <div class="course-meta">
                        <span><MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" /> @GetLessonCount(course) bai</span>
                        <span><MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Small" /> @GetLanguageName(course)</span>
                    </div>

                    <MudProgressLinear Value="@progressValue"
                                       Color="Color.Primary"
                                       Rounded="true"
                                       Class="course-progress" />

                    <div class="course-footer">
                        <strong>@GetCourseFocus(course)</strong>
                        <MudButton Href="@($"course/{course.Id}")"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   EndIcon="@Icons.Material.Filled.ArrowForward"
                                   Class="course-button">
                            Xem khoa
                        </MudButton>
                    </div>
                </MudPaper>
            }
        </div>
    </section>
</div>

@code {
    private static readonly IReadOnlyList<SocialLink> SocialLinks =
    [
        new("TikTok", "https://www.tiktok.com/@learninglangue", Icons.Material.Filled.MusicNote),
        new("YouTube", "https://www.youtube.com/@learninglangue", Icons.Material.Filled.OndemandVideo),
        new("Facebook", "https://www.facebook.com/learninglangue", Icons.Material.Filled.ThumbUp)
    ];

    private DashboardSummary? _summary;
    private IReadOnlyList<Course> _courses = [];

    protected override async Task OnInitializedAsync()
    {
        _summary = await Catalog.GetDashboardAsync(2);
        _courses = await Catalog.GetCoursesAsync();
    }

    private static bool IsPremiumCourse(Course course) =>
        !string.Equals(course.Level, "A1", StringComparison.OrdinalIgnoreCase);

    private static int GetCourseProgress(Course course) =>
        course.Id switch
        {
            1 => 84,
            2 => 68,
            3 => 46,
            _ => 52
        };

    private static string GetCourseTone(Course course) =>
        course.Language?.Code switch
        {
            "ja" => "tone-coral",
            "ko" => "tone-blue",
            "zh" => "tone-yellow",
            "fr" => "tone-indigo",
            _ => IsPremiumCourse(course) ? "tone-indigo" : "tone-green"
        };

    private static string GetCourseIcon(Course course) =>
        GetCourseFocus(course) switch
        {
            LessonTypes.Vocabulary => Icons.Material.Filled.Translate,
            LessonTypes.Grammar => Icons.Material.Filled.EditNote,
            LessonTypes.Speaking => Icons.Material.Filled.RecordVoiceOver,
            LessonTypes.Listening => Icons.Material.Filled.Headphones,
            _ => Icons.Material.Filled.School
        };

    private static int GetLessonCount(Course course) =>
        course.Units.Sum(unit => unit.Lessons.Count);

    private static string GetCourseFocus(Course course) =>
        course.Units
            .OrderBy(unit => unit.SortOrder)
            .SelectMany(unit => unit.Lessons.OrderBy(lesson => lesson.SortOrder))
            .Select(lesson => lesson.LessonType)
            .FirstOrDefault() ?? course.Level;

    private static string GetLanguageName(Course course) =>
        course.Language?.Name ?? "Ngon ngu";

    private sealed record SocialLink(string Name, string Url, string Icon);
}
