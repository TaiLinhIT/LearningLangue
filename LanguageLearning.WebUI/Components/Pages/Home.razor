@page "/"
@page "/about"
@inject ILearningCatalogService Catalog

<section class="hero app-section">
    <div class="hero-copy">
        <span class="pill">AI-ready language learning platform</span>
        <h1>LinguaFlow</h1>
        <p>Learn languages with joyful lessons, quizzes, XP, streaks, flashcards, speaking and listening practice, and a clear admin studio for content teams.</p>
        <div class="hero-actions">
            <a class="btn btn-primary btn-lg" href="/register">Start free</a>
            <a class="btn btn-light btn-lg" href="/courses">Explore courses</a>
        </div>
    </div>
</section>

<section class="app-section">
    <div class="section-title">
        <h2>Choose a language</h2>
        <p>Friendly learning paths by level, unit, lesson type, and practice mode.</p>
    </div>
    @if (_languages is null)
    {
        <div class="loading-state">Loading languages...</div>
    }
    else
    {
        <div class="grid grid-3">
            @foreach (var language in _languages)
            {
                <article class="cardx language-card">
                    <span class="flag">@language.FlagIcon</span>
                    <h3>@language.Name</h3>
                    <p class="muted">Course catalog, placement test, vocabulary, listening, speaking, and grammar practice.</p>
                    <a href="/courses">View courses</a>
                </article>
            }
        </div>
    }
</section>

<section class="app-section pt-0">
    <div class="grid grid-4">
        <div class="cardx stat"><strong>Placement</strong><span>Goal, language, and level test</span></div>
        <div class="cardx stat"><strong>Practice</strong><span>Vocabulary, listening, speaking, grammar</span></div>
        <div class="cardx stat"><strong>Motivation</strong><span>XP, streak, badges, leaderboard</span></div>
        <div class="cardx stat"><strong>Admin</strong><span>CRUD content, publish, reports</span></div>
    </div>
</section>

@code {
    private IReadOnlyList<Language>? _languages;

    protected override async Task OnInitializedAsync()
    {
        _languages = await Catalog.GetLanguagesAsync();
    }
}
